{
    "plugins": ["typescript"],
    "env": {
        "browser": true,
        "esnext": true,
        "node": true
    },
    "globals": {
        "afterAll": "readonly",
        "afterEach": "readonly",
        "beforeAll": "readonly",
        "beforeEach": "readonly",
        "describe": "readonly",
        "expect": "readonly",
        "it": "readonly",
        "test": "readonly",
        "vi": "readonly"
    },
    "categories": {
        "correctness": "error",
        "suspicious": "error",
        "perf": "warn"
    },
    "ignorePatterns": [
        "**/coverage/**",
        "**/dist/**",
        "**/docs/.docusaurus/**",
        "**/docs/build/**",
        "**/node_modules/**",
        "**/*.min.js"
    ],
    "rules": {
        "@typescript-eslint/consistent-type-imports": "off",
        "@typescript-eslint/no-explicit-any": "error",
        "@typescript-eslint/no-non-null-assertion": "off",
        "@typescript-eslint/no-unused-vars": "warn",
        "eqeqeq": ["error", "always", { "null": "ignore" }],
        "no-await-in-loop": "off",
        "no-console": "warn",
        "no-debugger": "error",
        "no-shadow": "off",
        "no-underscore-dangle": "off",
        "no-unused-vars": "off",
        "prefer-const": "error"
    },
    "overrides": [
        {
            "files": [
                "**/*.spec.ts",
                "**/*.spec.tsx",
                "**/*.test.ts",
                "**/*.test.tsx",
                "**/tests/**",
                "examples/**"
            ],
            "rules": {
                "@typescript-eslint/no-explicit-any": "off",
                "no-console": "off",
                "no-unused-vars": "off"
            }
        }
    ]
}
