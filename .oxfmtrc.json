{
    "printWidth": 120,
    "useTabs": false,
    "tabWidth": 4,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "ignorePatterns": [
        "**/*.md",
        "**/*.mdx",
        "**/coverage/**",
        "**/dist/**",
        "**/docs/.docusaurus/**",
        "**/docs/build/**",
        "**/node_modules/**",
        "**/*.min.js"
    ],
    "overrides": [
        {
            "files": ["**/*.json", "**/*.jsonc"],
            "options": {
                "trailingComma": "none"
            }
        }
    ]
}
